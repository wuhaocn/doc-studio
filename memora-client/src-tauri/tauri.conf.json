{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 0.0.0.0 --port 1420",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Memora Client",
    "version": "0.1.0"
  },
  "tauri": {
    "bundle": {
      "active": false,
      "identifier": "com.memora.client",
      "icon": [],
      "targets": "all"
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Memora Client",
        "width": 1320,
        "height": 860,
        "resizable": true
      }
    ]
  }
}
